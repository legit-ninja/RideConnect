# Database
DATABASE_URL=postgresql://rideconnect:rideconnect@db:5432/rideconnect

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Stripe (placeholders for future integration)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_CLIENT_ID=
PLATFORM_COMMISSION_PERCENT=10

# CORS
CORS_ORIGINS=http://localhost:3000

# Bootstrap admin (dev only — set strong values locally, never commit .env)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# OAuth (Facebook)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# OAuth frontend landing pages (browser redirect after backend callback)
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000/auth/callback
FRONTEND_OAUTH_ERROR_URL=http://localhost:3000/auth/error

# Search defaults (Appalachian NC launch region)
SEARCH_DEFAULT_LAT=36.2168
SEARCH_DEFAULT_LNG=-81.6746
SEARCH_DEFAULT_RADIUS_KM=80

# Weather (Open-Meteo — no API key)
WEATHER_TIMEZONE=America/New_York
WEATHER_CACHE_TTL_SECONDS=10800

# Public map jitter (deterministic per animal; change rotates all public pins)
LOCATION_JITTER_SECRET=dev-change-me

# File uploads (local filesystem in dev)
UPLOAD_ROOT=uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8000/uploads
PHOTO_MODERATION_ENABLED=false
FRONTEND_BASE_URL=http://localhost:3000
